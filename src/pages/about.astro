---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Icon from "../components/Icon.astro";
import { SITE, authors } from "../lib/blog-data.js";

const friends = authors.filter((a) => a.display !== false && a.url);
---

<BaseLayout
  title={`About - ${SITE.name}`}
  description={`About ${SITE.name}: travel, photography, and the occasional thought.`}
  canonical="/about"
>
  <div class="mx-auto max-w-3xl px-5 py-12">
    <Breadcrumbs items={[{ label: "Home", to: "/" }, { label: "About" }]} />

    <header class="mt-6">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">About</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold leading-[1.05]">
        About me.
      </h1>
    </header>

    <div class="prose-article mt-10">
      <p>
        I'm Xiaoyun &mdash; a traveler with a camera, occasionally writing things down.
      </p>
      <p>
        This blog is where I keep the stuff that doesn't fit anywhere else: field notes from the road,
        photographs of places that stopped me in my tracks, and the odd thought that felt worth putting into words.
        No schedules, no algorithms, no hot takes. Just slow, honest observations from a life spent mostly outdoors.
      </p>

      <h2 id="what-youll-find">What you'll find here</h2>
      <ul>
        <li><strong>Travelogues</strong> &mdash; stories from Xinjiang, Inner Mongolia, and wherever I wander next</li>
        <li><strong>Photography</strong> &mdash; landscapes, trails, and the decisive moments I managed to catch</li>
        <li><strong>Notes &amp; essays</strong> &mdash; life hacks, tech tips, and random musings</li>
      </ul>

      <h2 id="find-me">Find me</h2>
      <p>
        Follow my photos on <a href="https://www.xiaohongshu.com/user/profile/634e0ff0000000001901d429" target="_blank" rel="noopener noreferrer">Xiaohongshu </a>
        or check out my <a href="https://academic.liuxy.space" target="_blank" rel="noopener noreferrer">academic page</a> for the other side of my life.
      </p>
    </div>

    {friends.length > 0 && (
      <section class="mt-12 border-t border-border pt-10">
        <h2 class="font-serif text-2xl font-semibold">Friends</h2>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {friends.map((friend) => (
            <a href={friend.url} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-3">
              <img src={friend.avatar} alt="" width="48" height="48" class="h-12 w-12 rounded-full object-cover" />
              <div>
                <div class="font-serif text-base font-semibold group-hover:text-primary">{friend.name}</div>
                <div class="mt-1 text-sm text-muted-foreground">{friend.bio}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
