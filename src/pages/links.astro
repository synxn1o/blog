---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Icon from "../components/Icon.astro";
import { SITE, authors } from "../lib/blog-data.js";
import linkGroups from "../data/links.json";

const friends = authors.filter((a) => a.display !== false && a.url);
---

<BaseLayout
  title={`Links - ${SITE.name}`}
  description="Blogs, photographers, and places worth visiting on the web."
  canonical="/links"
>
  <div class="mx-auto max-w-4xl px-5 py-12">
    <Breadcrumbs items={[{ label: "Home", to: "/" }, { label: "Links" }]} />
    <h1 class="mt-4 font-serif text-4xl font-semibold sm:text-5xl">Links</h1>
    <p class="mt-3 max-w-xl text-muted-foreground">
      Blogs, photographers, and places worth visiting on the web.
    </p>

    <div class="mt-10 space-y-12">
      {friends.length > 0 && (
        <section>
          <h2 class="font-serif text-2xl font-semibold">Friends</h2>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            {friends.map((friend) => (
              <a
                href={friend.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 rounded-md border border-border/60 p-4 transition-colors hover:border-primary/30 hover:bg-muted/50"
              >
                <img src={friend.avatar} alt="" width="40" height="40" class="h-10 w-10 rounded-full object-cover" decoding="async"/>
                <div class="min-w-0 flex-1">
                  <div class="font-serif text-base font-medium group-hover:text-primary">{friend.name}</div>
                  <div class="mt-0.5 truncate text-sm text-muted-foreground">{friend.bio}</div>
                </div>
                <Icon name="arrow-right" class="h-4 w-4 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-primary" />
              </a>
            ))}
          </div>
        </section>
      )}

      {linkGroups.map((group) => (
        group.links.length > 0 && (
          <section>
            <h2 class="font-serif text-2xl font-semibold">{group.category}</h2>
            <div class="mt-4 space-y-4">
              {group.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-md border border-border/60 p-4 transition-colors hover:border-primary/30 hover:bg-muted/50"
                >
                  <div class="flex items-center justify-between">
                    <h3 class="font-serif text-lg font-medium group-hover:text-primary">
                      {link.title}
                    </h3>
                    <Icon name="arrow-right" class="h-4 w-4 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-primary" />
                  </div>
                  {link.description && (
                    <p class="mt-1 text-sm text-muted-foreground">{link.description}</p>
                  )}
                </a>
              ))}
            </div>
          </section>
        )
      ))}
    </div>
  </div>
</BaseLayout>
