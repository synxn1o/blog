---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import Icon from "../components/Icon.astro";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import {
  SITE,
  allCategories,
  sortedPosts,
  getAuthor,
  getCategory,
  formatDate,
} from "../lib/blog-data.js";

const posts = await sortedPosts();
const categories = await allCategories();

const parseImages = (body) =>
  [...(body ?? "").matchAll(/!\[([^\]]*)\]\(([^)\s]+)(?:\s+"([^"]*)")?\)/g)].map(
    ([, alt, src, remark]) => ({ src, alt, remark }),
  );

const heroEntry = await getEntry("photowall", "heroimages");
const heroImages = parseImages(heroEntry?.body);
const photoEntry = await getEntry("photowall", "photowall");
const firstPhoto = parseImages(photoEntry?.body)[0];
---

<BaseLayout
  title={`${SITE.name} - Writing, design & the slow web`}
  description={SITE.description}
  canonical="/"
  flushFooter
>
  <!-- Hero section with rolling images -->
  <section class="relative -mt-[calc(4rem+2px)] min-h-[calc(100svh-2rem)] overflow-hidden border-b border-border/60 pt-[calc(4rem+2px)] sm:min-h-[760px]" data-hero>
    <div class="absolute inset-0" data-hero-images>
      {heroImages.map((image, index) => (
        <Image
          src={image.src}
          alt={image.alt}
          inferSize
          format="webp"
          quality={95}
          widths={[640, 960, 1280, 1600, 1920]}
          sizes="(min-width: 1280px) 1280px, 100vw"
          class={`absolute inset-0 h-full w-full object-cover object-center transition-opacity duration-1000 ${index === 0 ? "" : "opacity-0"}`}
          loading={index === 0 ? "eager" : "lazy"}
          fetchpriority={index === 0 ? "high" : undefined}
          decoding="async"
          data-hero-image
        />
      ))}
    </div>
    <div
      aria-hidden="true"
      class="absolute inset-0 bg-[linear-gradient(90deg,oklch(0.1_0.02_70_/_0.68),oklch(0.16_0.02_80_/_0.38)_46%,oklch(0.98_0.01_90_/_0.1))] dark:bg-[linear-gradient(90deg,oklch(0.08_0.01_70_/_0.78),oklch(0.08_0.01_70_/_0.52)_48%,oklch(0.08_0.01_70_/_0.18))]"
    />
    <div
      aria-hidden="true"
      class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/45 via-black/18 to-transparent"
    />
    <div
      aria-hidden="true"
      class="absolute inset-x-0 bottom-0 h-8 dark:h-48 bg-gradient-to-t from-background via-background/72 to-transparent"
    />
    <div class="relative mx-auto flex min-h-[calc(100svh-6rem)] max-w-6xl items-center px-5 py-20 sm:min-h-[680px] sm:py-24">
      <div class="max-w-4xl text-white drop-shadow-[0_1px_18px_rgba(0,0,0,0.28)]">
        <h1 class="font-serif text-[2.5rem] font-medium leading-[1.02] sm:text-6xl lg:text-7xl">
        All I ever wanted was to
          <span class="italic text-white"> touch eternity </span>for an instant.
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-white/86">
          想要触碰世上那些永恒的瞬间.
        </p>
        
      </div>
    </div>
  </section>

  <!-- Photowall link section -->
  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="mb-6 flex items-center justify-between">
        <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Photowall</div>
        <a href="/photowall" class="text-xs text-muted-foreground hover:text-foreground">View all photos &rarr;</a>
      </div>
      <a href="/photowall" class="group block" aria-label="Visit the photowall">
        <article class="grid gap-10 lg:grid-cols-2">
          <div class="aspect-[4/3] overflow-hidden rounded-md bg-muted">
            {firstPhoto && (
              <Image
                src={firstPhoto.src}
                alt={firstPhoto.alt}
                inferSize
                format="webp"
                quality={88}
                widths={[320, 480, 640, 960]}
                sizes="(min-width: 1024px) 560px, calc(100vw - 40px)"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            )}
          </div>
          <div class="flex flex-col justify-center">
            <h2 class="font-serif text-3xl font-semibold leading-tight group-hover:text-primary sm:text-4xl">
              See my Photographics
            </h2>
            <p class="mt-4 text-lg text-muted-foreground">
              A collection of photographs capturing quiet moments and everyday beauty.
            </p>
            <div class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-primary">
              Browse the gallery <Icon name="arrow-right" class="h-3.5 w-3.5" />
            </div>
          </div>
        </article>
      </a>
    </div>
  </section>

  <!-- Latest section with blog list layout -->
  <section class="mx-auto max-w-6xl px-5 py-16" data-home-latest>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <h2 class="font-serif text-2xl font-semibold">Latest</h2>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          data-home-filter=""
          class="rounded-full border px-3 py-1 text-xs transition-colors border-foreground bg-foreground text-background"
        >
          All
        </button>
        {
          categories.map((category) => (
            <button
              type="button"
              data-home-filter={category.slug}
              class="rounded-full border px-3 py-1 text-xs transition-colors border-border text-muted-foreground hover:text-foreground"
            >
              {category.name}
            </button>
          ))
        }
      </div>
    </div>

    <div data-home-empty class="mt-12 rounded-md border border-dashed border-border py-16 text-center text-muted-foreground" hidden>
      Nothing here yet in this section.
    </div>

    <div data-home-list class="mt-10">
      {posts.map((post) => <PostCard post={post} variant="list" />)}
    </div>

    <div data-home-more-wrap class="mt-8 text-center" hidden>
      <button
        type="button"
        data-home-more
        class="rounded-md border border-border px-5 py-2.5 text-sm font-medium hover:bg-muted"
      ></button>
    </div>

    <div class="mt-4 text-center">
      <a href="/blog" class="text-sm text-muted-foreground underline underline-offset-4 hover:text-foreground">
        Browse the archive
      </a>
    </div>
  </section>

  <Newsletter />
</BaseLayout>

<script>
  // Rolling images for hero section
  const hero = document.querySelector("[data-hero]");
  if (hero) {
    const images = hero.querySelectorAll("[data-hero-image]");
    if (images.length > 1) {
      let currentIndex = 0;
      setInterval(() => {
        images[currentIndex].style.opacity = "0";
        currentIndex = (currentIndex + 1) % images.length;
        images[currentIndex].style.opacity = "1";
      }, 9000);
    }
  }

  // Category filter + load more for latest section
  const latest = document.querySelector("[data-home-latest]");
  if (latest) {
    const pageSize = 5;
    const buttons = [...latest.querySelectorAll("[data-home-filter]")];
    const cards = [...latest.querySelectorAll("[data-post-card]")];
    const empty = latest.querySelector("[data-home-empty]");
    const moreWrap = latest.querySelector("[data-home-more-wrap]");
    const more = latest.querySelector("[data-home-more]");
    const activeClasses = ["border-foreground", "bg-foreground", "text-background"];
    const inactiveClasses = ["border-border", "text-muted-foreground", "hover:text-foreground"];

    const setActive = (button, active) => {
      button.classList.toggle(activeClasses[0], active);
      button.classList.toggle(activeClasses[1], active);
      button.classList.toggle(activeClasses[2], active);
      inactiveClasses.forEach((className) => button.classList.toggle(className, !active));
    };

    let currentCategory = "";
    let page = 1;

    const render = () => {
      const matches = cards.filter(
        (card) => !currentCategory || card.dataset.category === currentCategory,
      );
      const visibleCount = Math.min(matches.length, page * pageSize);

      cards.forEach((card) => (card.hidden = true));
      matches.slice(0, visibleCount).forEach((card) => (card.hidden = false));

      if (empty) empty.hidden = matches.length > 0;
      moreWrap.hidden = visibleCount >= matches.length;
      more.textContent = `Load more (${matches.length - visibleCount} remaining)`;

      buttons.forEach((button) =>
        setActive(button, (button.dataset.homeFilter || "") === currentCategory),
      );
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        currentCategory = button.dataset.homeFilter || "";
        page = 1;
        render();
      });
    });

    more.addEventListener("click", () => {
      page++;
      render();
    });

    render();
  }
</script>
