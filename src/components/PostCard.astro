---
import { Image } from "astro:assets";
import { getCategory, formatDate } from "../lib/blog-data.js";

const { post, variant = "default", hidden = false } = Astro.props;
const category = await getCategory(post.category);
const categorySlug = post.category?.toLowerCase().replace(/\s+/g, "-") ?? "";
---

{
  variant === "compact" ? (
    <a
      href={`/blog/${post.slug}`}
      class="group block"
      data-post-card
      data-category={categorySlug}
      data-tags={post.tags.map((t) => t.toLowerCase().replace(/\s+/g, "-")).join(" ")}
      hidden={hidden}
    >
      <div class="text-xs uppercase tracking-wider text-muted-foreground">{category?.name}</div>
      <h3 class="mt-1 font-serif text-lg font-semibold leading-snug text-foreground group-hover:text-primary">
        {post.title}
      </h3>
      <div class="mt-1 text-xs text-muted-foreground">
        {formatDate(post.date)} &middot; {post.readingTime} min
      </div>
    </a>
  ) : variant === "list" ? (
    <article
      class="group grid gap-6 border-b border-border/60 py-8 sm:grid-cols-[1fr_220px]"
      data-post-card
      data-category={categorySlug}
      data-tags={post.tags.map((t) => t.toLowerCase().replace(/\s+/g, "-")).join(" ")}
      hidden={hidden}
    >
      <div>
        <div class="flex items-center gap-3 text-xs uppercase tracking-wider text-muted-foreground">
          {category && (
            <a href={`/categories/${category.slug}`} class="inline-flex min-h-9 items-center hover:text-foreground">
              {category.name}
            </a>
          )}
          <span>&middot;</span>
          <time datetime={post.date}>{formatDate(post.date)}</time>
        </div>
        <a href={`/blog/${post.slug}`} class="mt-1 block py-1">
          <h2 class="font-serif text-2xl font-semibold leading-tight group-hover:text-primary sm:text-3xl">
            {post.title}
          </h2>
        </a>
        <p class="mt-3 text-muted-foreground">{post.excerpt}</p>
        <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
          {post.tags?.slice(0, 3).map((tag) => (
            <a
              href={`/blog?tag=${tag.toLowerCase().replace(/\s+/g, "-")}`}
              class="rounded-full border border-border px-2 py-0.5 hover:border-primary hover:text-primary"
            >
              #{tag}
            </a>
          ))}
          <span>&middot;</span>
          <span>{post.readingTime} min read</span>
        </div>
      </div>
      {post.thumbnail && (
        <a href={`/blog/${post.slug}`} class="block" aria-label={`Read ${post.title}`}>
          <div class="aspect-[4/3] overflow-hidden rounded-md bg-muted sm:aspect-square">
            <Image
              src={post.thumbnail}
              alt=""
              loading="lazy"
              width={440}
              height={330}
              widths={[320, 440, 640]}
              sizes="(min-width: 640px) 220px, calc(100vw - 40px)"
              format="webp"
              quality={64}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
            />
          </div>
        </a>
      )}
    </article>
  ) : (
    <article
      class="group"
      data-post-card
      data-category={categorySlug}
      data-tags={post.tags.map((t) => t.toLowerCase().replace(/\s+/g, "-")).join(" ")}
      hidden={hidden}
    >
      {post.thumbnail && (
        <a href={`/blog/${post.slug}`} class="block" aria-label={`Read ${post.title}`}>
          <div class="aspect-[16/10] overflow-hidden rounded-md bg-muted">
            <Image
              src={post.thumbnail}
              alt=""
              loading="lazy"
              width={480}
              height={300}
              widths={[320, 384, 480, 640]}
              sizes="(min-width: 1024px) 352px, (min-width: 640px) calc((100vw - 80px) / 2), calc(100vw - 40px)"
              format="webp"
              quality={64}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
            />
          </div>
        </a>
      )}
      <div class="mt-4">
        <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-muted-foreground">
          {category && (
            <a href={`/categories/${category.slug}`} class="inline-flex min-h-9 items-center hover:text-foreground">
              {category.name}
            </a>
          )}
          <span>&middot;</span>
          <time datetime={post.date}>{formatDate(post.date)}</time>
        </div>
        <a href={`/blog/${post.slug}`} class="mt-1 block py-1">
          <h3 class="font-serif text-xl font-semibold leading-snug group-hover:text-primary">
            {post.title}
          </h3>
        </a>
        <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">{post.excerpt}</p>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
          {post.tags?.slice(0, 3).map((tag) => (
            <a
              href={`/blog?tag=${tag.toLowerCase().replace(/\s+/g, "-")}`}
              class="rounded-full border border-border px-2 py-0.5 hover:border-primary hover:text-primary"
            >
              #{tag}
            </a>
          ))}
          <span>&middot;</span>
          <span>{post.readingTime} min</span>
        </div>
      </div>
    </article>
  )
}
