---
import { FORMS } from "../config/theme.config.ts";
import Icon from "./Icon.astro";

const { compact = false } = Astro.props;
---

{
  compact ? (
    <div>
      <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Subscribe</div>
      <p class="mt-2 text-sm text-muted-foreground">Get new posts via RSS.</p>
      <a
        href="/rss.xml"
        class="mt-3 inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-sm font-medium hover:border-primary hover:text-primary"
      >
        <Icon name="rss" class="h-3.5 w-3.5" /> RSS Feed
      </a>
    </div>
  ) : (
    <section data-newsletter-cta class="border-t border-border/60 pt-16 pb-10">
      <div class="mx-auto max-w-2xl px-5 text-center">
        <h2 class="font-serif text-3xl font-semibold sm:text-4xl">Stay in the loop.</h2>
        <p class="mt-3 text-muted-foreground">
          Subscribe via RSS &mdash; new travelogues, photographs, and the occasional thought.
        </p>
        <a
          href="/rss.xml"
          class="mt-6 inline-flex items-center gap-2 rounded-md bg-foreground px-5 py-3 text-sm font-medium text-background transition-opacity hover:opacity-90"
        >
          <Icon name="rss" class="h-4 w-4" /> Subscribe via RSS
        </a>
      </div>
    </section>
  )
}
